<%- include('partials/header', { titulli: 'Regjistrohu' }) %>

<div class="tm-auth-page">
  <div class="tm-auth-card" style="max-width:460px">
    <div class="card-body">
      <div class="tm-auth-brand">
        <div class="brand-logo"><i class="bi bi-box-seam-fill"></i></div>
        <h1>TIRAMOTO</h1>
        <p>Krijo llogarinë tënde</p>
      </div>

      <% if (gabim) { %>
      <div class="tm-alert tm-alert-danger mb-3">
        <i class="bi bi-exclamation-circle"></i>
        <span><%= gabim %></span>
      </div>
      <% } %>

      <form method="POST" action="/regjistrohu">
        <div class="mb-3">
          <label class="form-label">Emri i plotë</label>
          <input type="text" name="emri" class="form-control" placeholder="p.sh. Andi Hoxha" required autofocus>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" placeholder="emaili@juaj.com" required>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Telefoni</label>
            <input type="tel" name="telefoni" class="form-control" placeholder="+355 6X XXX XXXX">
          </div>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Fjalëkalimi</label>
            <input type="password" name="fjalekalimi" class="form-control" minlength="6" required>
            <div class="form-text">Së paku 6 karaktere</div>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Konfirmo</label>
            <input type="password" name="fjalekalimi2" class="form-control" minlength="6" required>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">
          Krijo llogarinë <i class="bi bi-arrow-right"></i>
        </button>
      </form>

      <div class="tm-auth-divider">ose</div>

      <a href="/auth/google" class="btn-google">
        <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
        Regjistrohu me Google
      </a>

      <p class="text-center mb-0 mt-3" style="font-size:0.9rem">
        Ke llogari? <a href="/hyr" style="color:var(--primary);font-weight:600;text-decoration:none">Hyr këtu</a>
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<%- include('../partials/header', { titulli: 'Paneli i admin' }) %>

<div class="tm-page-header">
  <div>
    <h1>Paneli</h1>
    <p class="subtitle">Menaxho porositë dhe konfirmo kërkesat e korrierëve</p>
  </div>
</div>

<% if (numrat.ne_pritje > 0) { %>
<div class="tm-alert tm-alert-warning mb-4" style="display:flex;align-items:center;justify-content:space-between">
  <span><i class="bi bi-bell-fill"></i> <strong><%= numrat.ne_pritje %></strong> porosi presin konfirmimin tënd!</span>
  <a href="/admin?statusi=NE_PRITJE" class="btn btn-warning btn-sm">Shiko tani</a>
</div>
<% } %>

<!-- Stat cards -->
<div class="row g-3 mb-4">
  <div class="col-6 col-lg">
    <a href="/admin" class="tm-stat <%= !statusi ? 'active' : '' %>">
      <div class="tm-stat-number"><%= numrat.te_gjitha %></div>
      <div class="tm-stat-label">Të gjitha</div>
    </a>
  </div>
  <div class="col-6 col-lg">
    <a href="/admin?statusi=E_RE" class="tm-stat <%= statusi === 'E_RE' ? 'active' : '' %>">
      <div class="tm-stat-number" style="color:var(--primary)"><%= numrat.e_re %></div>
      <div class="tm-stat-label">E Re</div>
    </a>
  </div>
  <div class="col-6 col-lg">
    <a href="/admin?statusi=NE_PRITJE" class="tm-stat <%= statusi === 'NE_PRITJE' ? 'active' : '' %>" style="<%= numrat.ne_pritje > 0 ? 'border-color:var(--warning);background:rgba(255,193,7,0.05)' : '' %>">
      <div class="tm-stat-number" style="color:var(--warning)"><%= numrat.ne_pritje %></div>
      <div class="tm-stat-label">Në pritje</div>
    </a>
  </div>
  <div class="col-6 col-lg">
    <a href="/admin?statusi=CAKTUAR" class="tm-stat <%= statusi === 'CAKTUAR' ? 'active' : '' %>">
      <div class="tm-stat-number" style="color:var(--info, #0dcaf0)"><%= numrat.caktuar %></div>
      <div class="tm-stat-label">Caktuar</div>
    </a>
  </div>
  <div class="col-6 col-lg">
    <a href="/admin?statusi=MARRE" class="tm-stat <%= statusi === 'MARRE' ? 'active' : '' %>">
      <div class="tm-stat-number" style="color:var(--secondary)"><%= numrat.marre %></div>
      <div class="tm-stat-label">Marrë</div>
    </a>
  </div>
  <div class="col-6 col-lg">
    <a href="/admin?statusi=DOREZUAR" class="tm-stat <%= statusi === 'DOREZUAR' ? 'active' : '' %>">
      <div class="tm-stat-number" style="color:var(--success)"><%= numrat.dorezuar %></div>
      <div class="tm-stat-label">Dorëzuar</div>
    </a>
  </div>
  <div class="col-6 col-lg">
    <a href="/admin?statusi=ANULUAR" class="tm-stat <%= statusi === 'ANULUAR' ? 'active' : '' %>">
      <div class="tm-stat-number" style="color:var(--danger)"><%= numrat.anuluar %></div>
      <div class="tm-stat-label">Anuluar</div>
    </a>
  </div>
</div>

<!-- Orders table -->
<div class="tm-card" style="overflow:hidden">
  <div style="overflow-x:auto">
    <table class="tm-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Klienti</th>
          <th>Artikulli</th>
          <th>Rruga</th>
          <th>Korrier</th>
          <th>Statusi</th>
          <th>Data</th>
          <th style="text-align:right">Veprime</th>
        </tr>
      </thead>
      <tbody>
        <% if (porosite.length === 0) { %>
        <tr>
          <td colspan="8" style="text-align:center;padding:3rem 1rem;color:var(--gray-400)">
            <i class="bi bi-inbox" style="font-size:1.5rem;display:block;margin-bottom:0.5rem"></i>
            Nuk ka porosi.
          </td>
        </tr>
        <% } %>
        <% porosite.forEach(p => { %>
        <tr>
          <td><strong style="color:var(--text)">#<%= p.id %></strong></td>
          <td style="font-weight:500"><%= p.klient_emri %></td>
          <td>
            <span style="background:var(--gray-100);padding:2px 8px;border-radius:var(--radius-full);font-size:0.8rem;font-weight:500">
              <%= p.pershkrimi %>
            </span>
          </td>
          <td>
            <div style="font-size:0.8rem;line-height:1.6">
              <div><span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--success);margin-right:6px"></span><%= p.adresa_marrjes %></div>
              <div><span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--danger);margin-right:6px"></span><%= p.adresa_dorezimit %></div>
            </div>
          </td>
          <td>
            <% if (p.korrier_emri) { %>
            <span style="font-weight:500"><%= p.korrier_emri %></span>
            <% } else { %>
            <span style="color:var(--gray-300);font-size:0.8rem">Në pritje...</span>
            <% } %>
          </td>
          <td><span class="tm-status tm-status-<%= p.statusi.toLowerCase() %>"><%= statusiLabel(p.statusi) %></span></td>
          <td><span style="font-size:0.8rem;color:var(--gray-400)"><%= new Date(p.krijuar_me).toLocaleString('sq-AL') %></span></td>
          <td style="text-align:right;white-space:nowrap">
            <% if (p.statusi === 'NE_PRITJE') { %>
            <form method="POST" action="/admin/porosi/<%= p.id %>/konfirmo" style="display:inline">
              <button type="submit" class="btn btn-success btn-sm" title="Konfirmo"><i class="bi bi-check-lg"></i></button>
            </form>
            <form method="POST" action="/admin/porosi/<%= p.id %>/refuzo" style="display:inline">
              <button type="submit" class="btn btn-outline-danger btn-sm" title="Refuzo"><i class="bi bi-x-lg"></i></button>
            </form>
            <% } %>
            <a href="/admin/porosi/<%= p.id %>" class="btn btn-ghost btn-sm" title="Shiko">
              <i class="bi bi-eye"></i>
            </a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
(function() {
  let lastNePritje = <%= numrat.ne_pritje %>;
  let lastERe = <%= numrat.e_re %>;
  let soundEnabled = true;

  if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
  }

  function playSound() {
    if (!soundEnabled) return;
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.frequency.value = 800;
      gain.gain.value = 0.3;
      osc.start();
      osc.stop(ctx.currentTime + 0.15);
      setTimeout(() => {
        const osc2 = ctx.createOscillator();
        const gain2 = ctx.createGain();
        osc2.connect(gain2);
        gain2.connect(ctx.destination);
        osc2.frequency.value = 1000;
        gain2.gain.value = 0.3;
        osc2.start();
        osc2.stop(ctx.currentTime + 0.2);
      }, 180);
    } catch(e) {}
  }

  function showNotification(title, body) {
    if ('Notification' in window && Notification.permission === 'granted') {
      const n = new Notification(title, { body, icon: '/favicon.ico', tag: 'tiramoto-admin' });
      n.onclick = () => { window.focus(); n.close(); };
    }
  }

  async function checkNotifications() {
    try {
      const res = await fetch('/admin/api/notifications');
      const data = await res.json();

      if (data.ne_pritje > lastNePritje) {
        const diff = data.ne_pritje - lastNePritje;
        playSound();
        showNotification('TIRAMOTO', diff + ' porosi të reja presin konfirmimin!');
      }

      if (data.e_re > lastERe) {
        const diff = data.e_re - lastERe;
        playSound();
        showNotification('TIRAMOTO', diff + ' porosi të reja u krijuan!');
      }

      lastNePritje = data.ne_pritje;
      lastERe = data.e_re;

      const badge = document.getElementById('notifBadge');
      if (badge) {
        badge.textContent = data.total;
        badge.style.display = data.total > 0 ? 'inline-flex' : 'none';
      }

      if (data.ne_pritje > 0 || data.e_re > 0) {
        document.title = '(' + data.total + ') Paneli - TIRAMOTO';
      } else {
        document.title = 'Paneli - TIRAMOTO';
      }
    } catch(e) {}
  }

  setInterval(checkNotifications, 20000);
  setTimeout(checkNotifications, 3000);
})();
</script>

<%- include('../partials/footer') %>
